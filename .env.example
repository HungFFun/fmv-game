# Copy file này thành .env rồi thay bằng chuỗi ngẫu nhiên dài (KHÔNG commit .env).
# Sinh nhanh:  openssl rand -hex 32

# Token quản trị cho /api/admin/* (bắt buộc đổi ở prod)
ADMIN_TOKEN=change-me-openssl-rand-hex-32

# Khóa ký URL media (HMAC). Đổi khóa => mọi URL media cũ hết hạn.
MEDIA_SIGNING_SECRET=change-me-openssl-rand-hex-32
